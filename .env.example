WA_API_KEY=change-me
WA_PORT=4000
WA_HOST=127.0.0.1
WA_DATA_DIR=./data
WA_MEDIA_DIR=./media
WA_MEDIA_LIFETIME_DAYS=180
WA_LOG_LEVEL=info
# Optional: if set, outgoing webhooks include an x-pigeon-signature HMAC-SHA256 header
WA_WEBHOOK_SECRET=
# Optional: MCP server only. When true, the AI send tools draft instead of sending to WhatsApp.
WA_MCP_READONLY=false
# Anti-spam guard for first-contact ("cold") messages — numbers that have never
# messaged you. Warm replies and group messages are never gated. Set to "off" to disable.
WA_SEND_GUARD=on
# No cold sends for this long after the session links/relinks (ms).
WA_GUARD_POST_CONNECT_MS=120000
# Minimum gap between two cold sends (ms).
WA_GUARD_COLD_MIN_GAP_MS=60000
# Max cold sends per rolling hour / day.
WA_GUARD_COLD_PER_HOUR=5
WA_GUARD_COLD_PER_DAY=20
